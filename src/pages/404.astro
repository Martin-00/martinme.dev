---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="404 - Page not found" description="This page doesn't exist." />
	</head>
	<body>
		<Header />
		<main>
			<div class="container glass-card">
				<h1>404</h1>
				<p>This page doesn't exist. Maybe it used to, maybe it never did.</p>
				<p><a href="/">Go home</a> or <a href="/blog">read the blog</a>.</p>
			</div>
		</main>
		<Footer />
		<style>
			.container {
				text-align: center;
				padding: 4em 2em;
			}
			h1 {
				font-size: 6em;
				color: var(--accent);
				margin-bottom: 0;
			}
		</style>
	</body>
</html>
