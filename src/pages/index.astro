---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 0.5em 0 1em;
			}
			.hero .accent {
				color: var(--accent);
				font-weight: 600;
			}
			.smallcaps {
				font-variant: small-caps;
				font-weight: 600;
				letter-spacing: 0.05em;
				color: rgba(255, 255, 255, 0.8);
			}
			.nav-text {
				font-size: 0.92em;
				color: rgba(255, 255, 255, 0.6);
				margin-top: 1em;
			}
			.nav-text a {
				text-decoration-thickness: 1px;
			}
			hr.section-break {
				border: none;
				border-top: 1px dotted rgba(255, 255, 255, 0.15);
				margin: 1.5em 0;
			}
			.section-title {
				font-size: 1.15em;
				margin-bottom: 0.5em;
				padding-bottom: 0.2em;
				display: inline-block;
				font-weight: 600;
				font-variant: small-caps;
			}
			.recent-posts ul {
				list-style: none;
				padding: 0;
			}
			.recent-posts li {
				padding: 0.5em 0;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
			}
			.recent-posts li:last-child {
				border-bottom: none;
			}
			.recent-posts li a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				text-decoration: none;
				gap: 1em;
				transition: color 0.15s ease;
			}
			.recent-posts li a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-weight: 600;
				color: #ffffff;
				margin: 0;
				transition: color 0.15s ease;
			}
			.post-date {
				font-size: 0.8em;
				color: rgba(255, 255, 255, 0.35);
				white-space: nowrap;
			}
			.all-posts {
				margin-top: 0.75em;
				font-size: 0.9em;
			}
			@media (max-width: 720px) {
				.recent-posts li a {
					flex-direction: column;
					gap: 0.15em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p>
					This is the website of <strong>Martin M. E.</strong> I am a
					<span class="accent">Data Engineer</span> based in Monterrey, Mexico.
					I build cloud infrastructure and data systems on AWS. I think in systems,
					tradeoffs, and diagrams.
				</p>
				<p>
					I believe technology is one of the most powerful forces humanity has ever created,
					and that power makes direction matter more than speed. Building fast is easy. Building
					toward something good is the real challenge. I care about reducing suffering, not just
					shipping features. I care about animal welfare, open data for public good, the responsible
					development of AI, and the question of how the systems we build shape the world we live in.
				</p>
				<p>
					In my engineering practice, I care about understanding <em>why</em> a solution works, not
					just how to implement it. I believe aesthetics are a core element of engineering, not
					decoration. I believe the superpower behind every great system isn't genius but iteration:
					build a small piece, test it, fix it, build more. I believe in documenting everything,
					thinking in tradeoffs, and always delivering something.
				</p>
				<p>
					When I'm not at a terminal, I'm probably cycling, reading, or going deep on whatever
					concept caught my curiosity this week.
				</p>
				<p class="nav-text">
					<span class="smallcaps">Navigation:</span>
					For my technical writing, see the <a href="/blog">blog</a>;
					for background and philosophy, see the <a href="/about">about page</a>;
					for code, see <a href="https://github.com/Martin-00" target="_blank" rel="noopener noreferrer">GitHub</a>.
				</p>
				<p class="nav-text">
					<span class="smallcaps">Stack:</span>
					AWS, Python, Terraform, SQL, Apache Iceberg, Athena, Glue, S3, CloudFront,
					OpenSearch, Docker, Kafka, DynamoDB, Lambda, Kubernetes.
				</p>
			</section>

			<hr class="section-break" />

			<section class="recent-posts">
				<h3 class="section-title">Recent writing</h3>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<p class="all-posts"><a href="/blog">All posts &rarr;</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>
