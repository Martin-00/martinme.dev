---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.page-title {
				text-align: center;
				margin: 0.5em 0 0.25em;
				padding-bottom: 0.5em;
			}
			.page-title h1 {
				font-size: 1.8em;
				font-weight: 650;
				margin: 0;
			}
			.page-title .subtitle {
				font-size: 0.95em;
				color: rgba(255, 255, 255, 0.5);
				margin-top: 0.2em;
			}
			hr.title-rule {
				border: none;
				border-top: 1px solid rgba(255, 255, 255, 0.1);
				margin: 0 0 1.25em 0;
			}
			.layout {
				display: flex;
				gap: 2em;
				align-items: flex-start;
			}
			.about-col {
				flex: 6;
				min-width: 0;
			}
			.projects-col {
				flex: 4;
				min-width: 0;
			}
			.about-col .accent {
				color: var(--accent);
				font-weight: 600;
			}
			.smallcaps {
				font-variant: small-caps;
				font-weight: 600;
				letter-spacing: 0.05em;
				color: rgba(255, 255, 255, 0.8);
			}
			.nav-text {
				font-size: 0.88em;
				color: rgba(255, 255, 255, 0.55);
				margin-top: 0.75em;
			}
			.nav-text a {
				text-decoration-thickness: 1px;
			}
			.projects-col h2 {
				font-size: 1.15em;
				font-variant: small-caps;
				font-weight: 600;
				margin: 0 0 0.75em 0;
			}
			.project-card {
				display: block;
				text-decoration: none;
				padding: 1.5em 1.25em;
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 6px;
				margin-bottom: 0.75em;
				transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
				position: relative;
				overflow: hidden;
			}
			.project-card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				background: rgba(251, 191, 36, 0.04);
			}
			.project-card .card-title {
				font-size: 1.2em;
				font-weight: 600;
				color: #ffffff;
				margin: 0;
				transition: color 0.2s ease;
			}
			.project-card:hover .card-title {
				color: var(--accent);
			}
			.project-card .card-desc {
				font-size: 0.82em;
				color: rgba(255, 255, 255, 0.45);
				margin: 0.3em 0 0;
			}
			.project-card.coming-soon {
				border-style: dashed;
			}
			.project-card.coming-soon .card-title {
				color: rgba(255, 255, 255, 0.35);
				font-style: italic;
			}
			.project-card.coming-soon:hover {
				transform: none;
				border-color: rgba(255, 255, 255, 0.15);
				background: rgba(255, 255, 255, 0.03);
				cursor: default;
			}
			.project-card.coming-soon:hover .card-title {
				color: rgba(255, 255, 255, 0.35);
			}
			@media (max-width: 720px) {
				.layout {
					flex-direction: column;
					gap: 1.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="glass-card">
				<div class="page-title">
					<h1>Martin M. E.</h1>
					<p class="subtitle">Data Engineer. Builder. Monterrey, Mexico.</p>
				</div>
				<hr class="title-rule" />

				<div class="layout">
					<div class="about-col">
						<p>
							This is the website of <strong>Martin M. E.</strong> I am a
							<span class="accent">Data Engineer</span> based in Monterrey, Mexico.
							I build cloud infrastructure and data systems on AWS. I think in systems,
							tradeoffs, and diagrams.
						</p>
						<p>
							I believe technology is one of the most powerful forces humanity has ever created,
							and that power makes direction matter more than speed. Building fast is easy. Building
							toward something good is the real challenge. I care about reducing suffering, not just
							shipping features. I care about animal welfare, open data for public good, the responsible
							development of AI, and the question of how the systems we build shape the world we live in.
						</p>
						<p>
							In my engineering practice, I care about understanding <em>why</em> a solution works, not
							just how to implement it. I believe aesthetics are a core element of engineering, not
							decoration. I believe the superpower behind every great system isn't genius but iteration:
							build a small piece, test it, fix it, build more.
						</p>
						<p>
							When I'm not at a terminal, I'm probably cycling, reading, or going deep on whatever
							concept caught my curiosity this week.
						</p>
						<p class="nav-text">
							<span class="smallcaps">Navigation:</span>
							For my technical writing, see the <a href="/blog">blog</a>;
							for background and philosophy, see the <a href="/about">about page</a>;
							for code, see <a href="https://github.com/Martin-00" target="_blank" rel="noopener noreferrer">GitHub</a>.
						</p>
						<p class="nav-text">
							<span class="smallcaps">Stack:</span>
							AWS, Python, Terraform, SQL, Apache Iceberg, Athena, Glue, S3, CloudFront,
							OpenSearch, Docker, Kafka, DynamoDB, Lambda, Kubernetes.
						</p>
					</div>

					<div class="projects-col">
						<h2>Projects</h2>
						<a href="/blog" class="project-card">
							<p class="card-title">Writings</p>
							<p class="card-desc">Technical and philosophical.</p>
						</a>
						<div class="project-card coming-soon">
							<p class="card-title">Coming soon</p>
							<p class="card-desc">More is being built.</p>
						</div>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
