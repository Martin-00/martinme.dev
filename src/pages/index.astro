---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.page-title {
				text-align: center;
				margin: 0.5em 0 0.25em;
				padding-bottom: 0.5em;
			}
			.page-title h1 {
				font-size: 1.8em;
				font-weight: 650;
				margin: 0;
			}
			.page-title .subtitle {
				font-size: 0.95em;
				color: rgba(255, 255, 255, 0.5);
				margin-top: 0.2em;
			}
			hr.title-rule {
				border: none;
				border-top: 1px solid rgba(255, 255, 255, 0.1);
				margin: 0 0 1.25em 0;
			}
			.layout {
				display: flex;
				gap: 2em;
				align-items: flex-start;
			}
			.about-col {
				flex: 6;
				min-width: 0;
			}
			.projects-col {
				flex: 4;
				min-width: 0;
			}
			.about-col .accent {
				color: var(--accent);
				font-weight: 600;
			}
			.smallcaps {
				font-variant: small-caps;
				font-weight: 600;
				letter-spacing: 0.05em;
				color: rgba(255, 255, 255, 0.8);
			}
			.nav-text {
				font-size: 0.88em;
				color: rgba(255, 255, 255, 0.55);
				margin-top: 0.75em;
			}
			.nav-text a {
				text-decoration-thickness: 1px;
			}
			.projects-col h2 {
				font-size: 1.15em;
				font-variant: small-caps;
				font-weight: 600;
				margin: 0 0 0.75em 0;
			}
			.project-card {
				display: block;
				text-decoration: none;
				padding: 1.5em 1.25em;
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 6px;
				margin-bottom: 0.75em;
				transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
				position: relative;
				overflow: hidden;
			}
			.project-card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				background: rgba(251, 191, 36, 0.04);
			}
			.project-card .card-title {
				font-size: 1.2em;
				font-weight: 600;
				color: #ffffff;
				margin: 0;
				transition: color 0.2s ease;
			}
			.project-card:hover .card-title {
				color: var(--accent);
			}
			.project-card .card-desc {
				font-size: 0.82em;
				color: rgba(255, 255, 255, 0.45);
				margin: 0.3em 0 0;
			}
			.project-card.coming-soon {
				border-style: dashed;
			}
			.project-card.coming-soon .card-title {
				color: rgba(255, 255, 255, 0.35);
				font-style: italic;
			}
			.project-card.coming-soon:hover {
				transform: none;
				border-color: rgba(255, 255, 255, 0.15);
				background: rgba(255, 255, 255, 0.03);
				cursor: default;
			}
			.project-card.coming-soon:hover .card-title {
				color: rgba(255, 255, 255, 0.35);
			}
			.writings-section {
				margin-top: 1.25em;
				padding-top: 1em;
				border-top: 1px dotted rgba(255, 255, 255, 0.1);
			}
			.writings-section h3 {
				font-size: 1em;
				font-variant: small-caps;
				font-weight: 600;
				margin: 0 0 0.5em 0;
			}
			.writings-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.writings-list li {
				padding: 0.3em 0;
			}
			.writings-list a {
				text-decoration: none;
				font-size: 0.9em;
				color: rgba(255, 255, 255, 0.8);
				transition: color 0.15s ease;
			}
			.writings-list a:hover {
				color: var(--accent);
			}
			.writings-list .date {
				font-size: 0.75em;
				color: rgba(255, 255, 255, 0.3);
				margin-left: 0.5em;
			}
			@media (max-width: 720px) {
				.layout {
					flex-direction: column;
					gap: 1.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="glass-card">
				<div class="page-title">
					<h1>Martin M. E.</h1>
					<p class="subtitle">Data Engineer. Builder. Monterrey, Mexico.</p>
				</div>
				<hr class="title-rule" />

				<div class="layout">
					<div class="about-col">
						<p>
							This is the website of <strong>Martin M. E.</strong> I care about the welfare
							of all beings, the future of existence, and the question of whether the things
							we build are making the world better or just making it faster. I think about
							animal welfare, the responsible development of AI, open data for public good,
							ecology, ethics, and what good leadership actually looks like.
						</p>
						<p>
							I am a <span class="accent">Data Engineer</span> based in Monterrey, Mexico.
							I build cloud infrastructure and data systems on AWS. I think in systems,
							tradeoffs, and diagrams. I believe the superpower behind every great system
							isn't genius but iteration: build a small piece, test it, fix it, build more.
							I care about understanding <em>why</em> things work, not just how to
							configure them. Technology is a vehicle. Where it goes matters more than how
							fast it moves.
						</p>
						<p>
							Beyond engineering, I'm a deeply curious person. I fall into rabbit holes
							about geography, history, the universe, human inventions, and whatever
							mystery grabbed my attention this week. I love cinema, music that carries
							meaning, art, architecture, sports (cycling, running, soccer, lifting),
							and the pursuit of optimal health: whole foods, sunlight, movement, and
							the belief that disease, suffering, and aging are problems we can solve
							with enough collective will and technology. I try to live by the scientific
							method: question your conclusions, question whether you're asking the
							right question, update when the evidence says so.
						</p>
						<p class="nav-text">
							<span class="smallcaps">Navigation:</span>
							For my technical writing, see <a href="/blog">writings</a>;
							for background and philosophy, see the <a href="/about">about page</a>;
							for code, see <a href="https://github.com/Martin-00" target="_blank" rel="noopener noreferrer">GitHub</a>.
						</p>
						<p class="nav-text">
							<span class="smallcaps">Stack:</span>
							AWS, Python, Terraform, SQL, Apache Iceberg, Athena, Glue, S3, CloudFront,
							OpenSearch, Docker, Kafka, DynamoDB, Lambda, Kubernetes.
						</p>
					</div>

					<div class="projects-col">
						<h2>Projects</h2>
						<a href="/blog" class="project-card">
							<p class="card-title">Writings</p>
							<p class="card-desc">Technical and philosophical.</p>
						</a>
						<div class="project-card coming-soon">
							<p class="card-title">Coming soon</p>
							<p class="card-desc">More is being built.</p>
						</div>
					</div>
				</div>

				<div class="writings-section">
					<h3>Top Writings</h3>
					<ul class="writings-list">
						{
							posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										{post.data.title}
										<span class="date"><FormattedDate date={post.data.pubDate} /></span>
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
