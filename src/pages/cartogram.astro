---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Mexico Cartogram - Interactive Population Map by Municipio"
			description="Interactive population cartogram of Mexico showing 2,476 municipios distorted by Census 2020 population. Toggle between cartogram and normal map. Color by population, state, election results. Built with D3.js and INEGI data."
			keywords="mexico cartogram, cartograma mexico, mexico population map, mexico municipios map, INEGI census 2020, mexico interactive map, mexico data visualization, cartogram D3, mexico election map, mexico population density, Gastner-Newman cartogram"
		/>
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "CreativeWork",
			"name": "Mexico Population Cartogram",
			"description": "Interactive cartogram of Mexico showing 2,476 municipios distorted by population from the INEGI Census 2020. Built with D3.js and the Gastner-Newman density-equalizing algorithm.",
			"author": {
				"@type": "Person",
				"name": "Martin Morales Estrada"
			},
			"datePublished": "2026-03-19",
			"url": "https://martinme.dev/cartogram",
			"keywords": ["cartogram", "Mexico", "population", "INEGI", "data visualization", "D3.js", "municipios"],
			"about": {
				"@type": "Place",
				"name": "Mexico"
			}
		}
		</script>
		<style>
			.cartogram-header {
				text-align: center;
				margin-bottom: 0.75em;
			}
			.cartogram-header h1 {
				font-size: 1.6em;
				margin: 0 0 0.2em;
			}
			.cartogram-header .subtitle {
				font-size: 0.9em;
				color: rgba(255, 255, 255, 0.5);
			}
			.controls {
				display: flex;
				justify-content: center;
				gap: 0.5em;
				margin-bottom: 0.5em;
				flex-wrap: wrap;
			}
			.controls button {
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.15);
				color: rgba(255, 255, 255, 0.7);
				padding: 0.35em 0.9em;
				font-family: 'Source Serif', Georgia, serif;
				font-size: 0.75em;
				letter-spacing: 0.05em;
				cursor: pointer;
				transition: all 0.15s ease;
			}
			.controls button:hover {
				background: rgba(255, 255, 255, 0.08);
				color: var(--accent);
			}
			.controls button.active {
				background: rgba(251, 191, 36, 0.1);
				border-color: var(--accent);
				color: var(--accent);
			}
			.control-group {
				display: flex;
				gap: 0;
			}
			.control-group button {
				margin-left: -1px;
			}
			.control-group button:first-child {
				margin-left: 0;
			}
			.control-separator {
				width: 1px;
				background: rgba(255, 255, 255, 0.1);
				margin: 0 0.75em;
			}
			#map-container {
				width: 100%;
				display: flex;
				justify-content: center;
			}
			#map-container svg {
				max-width: 100%;
				height: auto;
			}
			.tooltip {
				position: absolute;
				background: rgba(5, 10, 25, 0.92);
				border: 1px solid rgba(255, 255, 255, 0.15);
				border-radius: 4px;
				padding: 0.5em 0.75em;
				font-size: 0.8em;
				color: #f0f0f0;
				pointer-events: none;
				opacity: 0;
				transition: opacity 0.15s ease;
				z-index: 200;
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
			}
			.tooltip .tt-name {
				font-weight: 600;
				margin-bottom: 0.2em;
			}
			.tooltip .tt-value {
				color: rgba(255, 255, 255, 0.65);
				font-size: 0.9em;
			}
			.legend {
				display: flex;
				justify-content: center;
				gap: 1em;
				margin-top: 0.5em;
				flex-wrap: wrap;
				font-size: 0.75em;
				color: rgba(255, 255, 255, 0.5);
			}
			.legend-item {
				display: flex;
				align-items: center;
				gap: 0.35em;
			}
			.legend-swatch {
				width: 12px;
				height: 12px;
				border-radius: 2px;
			}
			.loading {
				text-align: center;
				color: rgba(255, 255, 255, 0.4);
				padding: 3em 0;
				font-style: italic;
			}
			.explanation {
				margin-top: 2em;
				padding-top: 1.5em;
				border-top: 1px dotted rgba(255, 255, 255, 0.1);
			}
			.explanation h2 {
				font-size: 1.2em;
				font-variant: small-caps;
				margin-bottom: 0.75em;
			}
			.explanation p {
				font-size: 0.92em;
				color: rgba(255, 255, 255, 0.8);
				line-height: 1.65;
			}
			.explanation-note {
				font-size: 0.8em !important;
				color: rgba(255, 255, 255, 0.4) !important;
				margin-top: 1.5em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="glass-card">
				<div class="cartogram-header">
					<h1>Mexico Cartogram</h1>
					<p class="subtitle">Land area distorted by population. INEGI Census 2020 + Marco Geoestadistico 2025.</p>
				</div>

				<div class="controls">
					<div class="control-group">
						<button id="btn-cartogram" class="active">Cartogram</button>
						<button id="btn-normal">Normal</button>
					</div>
					<div class="control-separator"></div>
					<div class="control-group">
						<button id="btn-mun" class="active">Municipios</button>
						<button id="btn-state">States</button>
					</div>
					<div class="control-separator"></div>
					<div class="control-group">
						<button class="color-btn active" data-variable="population">Population</button>
						<button class="color-btn" data-variable="state">By state</button>
					</div>
				</div>

				<div id="map-container">
					<div class="loading" id="loading">Loading map data...</div>
				</div>
				<div id="legend" class="legend"></div>
				<div class="tooltip" id="tooltip"></div>

				<div class="explanation">
					<h2>What the cartogram reveals</h2>
					<p>
						The massive central bulge is where Mexico's gravity lives: Ciudad de Mexico,
						Estado de Mexico, Puebla, and Guadalajara. On a standard map, these states
						look like they share the country equally with Chihuahua and Durango. On the
						cartogram, they ARE Mexico. The central highlands contain more people than the
						entire north combined.
					</p>
					<p>
						Monterrey stands out clearly in the northeast, the industrial capital of
						northern Mexico. Tijuana and Mexicali swell out of Baja California, revealing
						the border economy that a standard map hides behind the peninsula's long, thin
						shape. The Yucatan holds its form because Merida and Cancun carry real population
						weight. And the vast deserts of Chihuahua, Durango, and Sonora? Compressed to
						thin strips, because almost nobody lives there.
					</p>

					<h2>Why this matters</h2>
					<p>
						A standard map of Mexico allocates visual weight by land area. Chihuahua
						dominates the north. But Chihuahua has 3.7 million people. Estado de Mexico
						has 17 million. On a normal map, they look roughly equal. A cartogram corrects
						this by making area proportional to population: what the eye sees matches
						where the people actually are.
					</p>
					<p>
						Every policy debate, every resource allocation, every electoral analysis
						that uses a standard map is starting from a distortion. Land doesn't vote.
						Land doesn't need hospitals. Land doesn't experience poverty. People do.
						A cartogram replaces geographic bias with demographic truth.
					</p>
					<p>
						At the municipio level, the distortion is even more revealing. Within each
						state, population concentrates in a few urban centers while vast rural
						territories hold very few people. Toggle between "Normal" and "Cartogram" to
						see how dramatically the country reshapes when you measure by people instead
						of land.
					</p>

					<h2>How it was built</h2>
					<p>
						I built this cartogram with the help of AI in a single session. The
						boundaries come from INEGI's Marco Geoestadistico 2025 (2,476 municipios).
						The population data comes from the Census 2020 (126 million people). I used
						the Gastner-Newman density-equalizing algorithm, computed in Python with
						30 iterations and 1.15% average error. The rendering is D3.js, running
						entirely in your browser. The whole site runs on AWS S3 and CloudFront
						for $0.51/month. No backend, no API, no server.
					</p>
					<p class="explanation-note">
						<a href="https://github.com/Martin-00/martinme.dev" target="_blank" rel="noopener noreferrer">Source code on GitHub</a>.
						Data: INEGI Marco Geoestadistico 2025, Census 2020.
						Algorithm: Gastner-Newman density-equalizing cartogram.
					</p>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			import * as d3 from 'd3';
			import * as topojson from 'topojson-client';

			const width = 960;
			const height = 620;

			let mapMode = 'cartogram';
			let levelMode = 'mun';
			let colorVar = 'population';

			let data: Record<string, any> = {};

			const stateColors = [
				'#e6194b', '#3cb44b', '#ffe119', '#4363d8', '#f58231',
				'#911eb4', '#42d4f4', '#f032e6', '#bfef45', '#fabed4',
				'#469990', '#dcbeff', '#9A6324', '#fffac8', '#800000',
				'#aaffc3', '#808000', '#ffd8b1', '#000075', '#a9a9a9',
				'#e6beff', '#1abc9c', '#e74c3c', '#3498db', '#2ecc71',
				'#9b59b6', '#f39c12', '#1abc9c', '#e67e22', '#2980b9',
				'#27ae60', '#8e44ad'
			];

			const svg = d3.select('#map-container')
				.append('svg')
				.attr('viewBox', `0 0 ${width} ${height}`)
				.attr('preserveAspectRatio', 'xMidYMid meet')
				.style('display', 'none');

			const tooltip = d3.select('#tooltip');

			async function loadData() {
				const files = [
					['mun-cartogram', '/data/mexico-mun-cartogram.json'],
					['mun-normal', '/data/mexico-mun-normal.json'],
					['state-cartogram', '/data/mexico-cartogram.geojson'],
					['state-normal', '/data/mexico-normal.geojson'],
				];

				const results = await Promise.all(
					files.map(([key, url]) => fetch(url).then(r => r.json()).then(d => [key, d]))
				);

				for (const [key, d] of results) {
					if (d.type === 'Topology') {
						const objKey = Object.keys(d.objects)[0];
						data[key] = topojson.feature(d, d.objects[objKey]);
					} else {
						data[key] = d;
					}
				}

				document.getElementById('loading')!.style.display = 'none';
				svg.style('display', null);
				render();
			}

			function getDataKey(): string {
				return `${levelMode}-${mapMode === 'cartogram' ? 'cartogram' : 'normal'}`;
			}

			// Property accessors: mun files use short keys (n,p,e,c), state files use full names
			function getPop(d: any): number {
				return d.properties.p || d.properties.population || 0;
			}
			function getEnt(d: any): string {
				return d.properties.e || d.properties.CVE_ENT || d.properties.id || '00';
			}
			function getName(d: any): string {
				return d.properties.n || d.properties.NOMGEO || d.properties.name || 'Unknown';
			}

			function getColor(d: any): string {
				if (colorVar === 'population') {
					if (levelMode === 'mun') {
						// Log scale for municipios: huge range from 81 to 1.9M
						const scale = d3.scaleSequentialLog(d3.interpolateYlOrRd).domain([500, 2000000]);
						return scale(Math.max(500, getPop(d)));
					} else {
						const scale = d3.scaleSequentialLog(d3.interpolateYlOrRd).domain([500000, 17000000]);
						return scale(Math.max(500000, getPop(d)));
					}
				} else if (colorVar === 'state') {
					const idx = (parseInt(getEnt(d)) - 1) % stateColors.length;
					return stateColors[idx];
				} else if (colorVar === 'party_2024') {
					const colors: Record<string, string> = { 'MORENA': '#8B1A1A', 'PAN': '#1E3A8A', 'MC': '#F97316' };
					return colors[d.properties.party_2024] || '#666';
				} else if (colorVar === 'hdi') {
					const scale = d3.scaleSequential(d3.interpolateRdYlGn).domain([0.65, 0.87]);
					return scale(d.properties.hdi || 0.75);
				}
				return '#666';
			}

			function renderLegend() {
				const legend = d3.select('#legend');
				legend.html('');
				if (colorVar === 'population') {
					if (levelMode === 'mun') {
						const scale = d3.scaleSequentialLog(d3.interpolateYlOrRd).domain([500, 2000000]);
						const steps = [1000, 10000, 50000, 200000, 500000, 2000000];
						steps.forEach(v => {
							const label = v >= 1000000 ? `${(v/1000000).toFixed(0)}M` : `${(v/1000).toFixed(0)}K`;
							legend.append('div').attr('class', 'legend-item')
								.html(`<div class="legend-swatch" style="background:${scale(v)}"></div>${label}`);
						});
					} else {
						const scale = d3.scaleSequentialLog(d3.interpolateYlOrRd).domain([500000, 17000000]);
						const steps = [700000, 2000000, 5000000, 10000000, 17000000];
						steps.forEach(v => {
							const label = `${(v/1000000).toFixed(0)}M`;
							legend.append('div').attr('class', 'legend-item')
								.html(`<div class="legend-swatch" style="background:${scale(v)}"></div>${label}`);
						});
					}
				} else if (colorVar === 'party_2024') {
					const parties: Record<string, string> = { 'MORENA': '#8B1A1A', 'PAN': '#1E3A8A', 'MC': '#F97316' };
					Object.entries(parties).forEach(([p, c]) => {
						legend.append('div').attr('class', 'legend-item')
							.html(`<div class="legend-swatch" style="background:${c}"></div>${p}`);
					});
				}
			}

			function render() {
				const key = getDataKey();
				const geo = data[key];
				if (!geo) return;

				const projection = d3.geoMercator().fitSize([width, height], geo);
				const path = d3.geoPath().projection(projection);

				svg.selectAll('path').remove();

				svg.selectAll('path')
					.data(geo.features)
					.join('path')
					.attr('d', path as any)
					.attr('fill', (d: any) => getColor(d))
					.attr('stroke', levelMode === 'mun' ? 'rgba(0,0,0,0.15)' : 'rgba(255,255,255,0.2)')
					.attr('stroke-width', levelMode === 'mun' ? 0.25 : 0.5)
					.on('mouseover', function(event: MouseEvent, d: any) {
						d3.select(this)
							.attr('stroke', '#fbbf24')
							.attr('stroke-width', levelMode === 'mun' ? 1 : 2)
							.raise();
						const pop = getPop(d);
						tooltip.style('opacity', 1)
							.html(`<div class="tt-name">${getName(d)}</div>
								<div class="tt-value">Pop: ${pop ? pop.toLocaleString() : 'N/A'}</div>`);
					})
					.on('mousemove', function(event: MouseEvent) {
						tooltip
							.style('left', (event.pageX + 12) + 'px')
							.style('top', (event.pageY - 10) + 'px');
					})
					.on('mouseout', function() {
						d3.select(this)
							.attr('stroke', levelMode === 'mun' ? 'rgba(0,0,0,0.15)' : 'rgba(255,255,255,0.2)')
							.attr('stroke-width', levelMode === 'mun' ? 0.25 : 0.5);
						tooltip.style('opacity', 0);
					});

				renderLegend();
			}

			// Map mode toggle
			document.getElementById('btn-cartogram')?.addEventListener('click', () => {
				mapMode = 'cartogram';
				document.getElementById('btn-cartogram')?.classList.add('active');
				document.getElementById('btn-normal')?.classList.remove('active');
				render();
			});
			document.getElementById('btn-normal')?.addEventListener('click', () => {
				mapMode = 'normal';
				document.getElementById('btn-normal')?.classList.add('active');
				document.getElementById('btn-cartogram')?.classList.remove('active');
				render();
			});

			// Level toggle
			document.getElementById('btn-mun')?.addEventListener('click', () => {
				levelMode = 'mun';
				document.getElementById('btn-mun')?.classList.add('active');
				document.getElementById('btn-state')?.classList.remove('active');
				// Update color options
				updateColorButtons();
				render();
			});
			document.getElementById('btn-state')?.addEventListener('click', () => {
				levelMode = 'state';
				document.getElementById('btn-state')?.classList.add('active');
				document.getElementById('btn-mun')?.classList.remove('active');
				updateColorButtons();
				render();
			});

			function updateColorButtons() {
				const btns = document.querySelectorAll('.color-btn');
				btns.forEach(b => {
					const v = b.getAttribute('data-variable');
					if (levelMode === 'mun' && (v === 'party_2024' || v === 'hdi')) {
						(b as HTMLElement).style.display = 'none';
					} else {
						(b as HTMLElement).style.display = '';
					}
				});
				// Reset to population if current is hidden
				if (levelMode === 'mun' && (colorVar === 'party_2024' || colorVar === 'hdi')) {
					colorVar = 'population';
					btns.forEach(b => {
						b.classList.toggle('active', b.getAttribute('data-variable') === 'population');
					});
				}
			}

			// Color variable buttons
			document.querySelectorAll('.color-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));
					btn.classList.add('active');
					colorVar = btn.getAttribute('data-variable') || 'population';
					render();
				});
			});

			loadData();
		</script>
	</body>
</html>
