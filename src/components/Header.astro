---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">martinme.dev</a>
		<div class="nav-links">
			<HeaderLink href="/">HOME</HeaderLink>
			<HeaderLink href="/blog">BLOG</HeaderLink>
			<HeaderLink href="/about">ABOUT</HeaderLink>
			<a href="https://github.com/Martin-00" target="_blank" rel="noopener noreferrer">GITHUB</a>
			<a href="https://www.linkedin.com/in/martinmoralesestrada/" target="_blank" rel="noopener noreferrer">LINKEDIN</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: var(--glass);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--glass-border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2em;
		padding: 0.8em 0;
		max-width: 1000px;
		margin: 0 auto;
	}
	.site-title {
		font-size: 0.95em;
		font-weight: 600;
		color: #ffffff;
		text-decoration: none;
		letter-spacing: -0.01em;
		white-space: nowrap;
	}
	.site-title:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 0;
	}
	.nav-links a,
	.nav-links :global(a) {
		display: inline-block;
		padding: 0.5em 1.4em;
		color: var(--white);
		text-decoration: none;
		font-size: 0.75em;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		border: 1px solid rgba(255, 255, 255, 0.15);
		margin-left: -1px;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.nav-links a:first-child,
	.nav-links :global(a:first-child) {
		margin-left: 0;
	}
	.nav-links a:hover,
	.nav-links :global(a:hover) {
		background: rgba(255, 255, 255, 0.08);
		color: var(--accent);
	}
	.nav-links :global(a.active) {
		background: rgba(255, 255, 255, 0.06);
		color: var(--accent);
		font-weight: 700;
	}
	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}
		nav {
			flex-direction: column;
			gap: 0.5em;
		}
		.nav-links a,
		.nav-links :global(a) {
			padding: 0.4em 0.8em;
			font-size: 0.65em;
		}
	}
</style>
